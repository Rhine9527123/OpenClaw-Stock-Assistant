# OpenClaw Stock Assistant 环境配置模板
# 复制此文件为 .env 并填入你的实际配置

# ============================================
# 飞书企业应用配置（用于发送消息和图片）
# ============================================
# 在飞书开放平台创建企业应用获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书群聊 Chat ID
# 获取方式：在飞书群设置 -> 群机器人 -> 添加自定义机器人
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# 飞书群机器人 Webhook（可选，用于简单文本消息）
# ============================================
# 在飞书群设置 -> 群机器人 -> 添加自定义机器人 -> 复制 Webhook 地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================
# 股票监控配置
# ============================================
# 默认监控的股票代码（示例：科创板50ETF）
DEFAULT_STOCK_CODE=588000

# 监控的股票列表（逗号分隔）
WATCH_LIST=588000,000001,000858

# ============================================
# 定时任务配置
# ============================================
# 时区设置
TIMEZONE=Asia/Shanghai

# 晨报发送时间（24小时制，默认 09:00）
MORNING_REPORT_TIME=0 9 * * 1-5

# 收盘报告发送时间（默认 20:00）
CLOSE_REPORT_TIME=0 20 * * 1-5

# ============================================
# 数据配置
# ============================================
# 数据缓存时间（分钟）
CACHE_MINUTES=5

# 图表保存天数
CHART_RETENTION_DAYS=7

# 报告保存天数
REPORT_RETENTION_DAYS=30

# ============================================
# 可选：外部 API 配置
# ============================================
# 如需使用其他数据源，可在此配置
# TUSHARE_TOKEN=your_tushare_token
# AKSHARE_ENABLE=true

# ============================================
# 日志配置
# ============================================
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志保留天数
LOG_RETENTION_DAYS=30
